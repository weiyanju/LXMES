<UserControl x:Class="VfdControl.App.Views.Admin.BarcodeRuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VfdControl.App;component/Resources/IndustrialTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="RuleLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource IndustrialTextMutedBrush}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Border Style="{StaticResource IndustrialModulePanelStyle}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                <TextBlock Text="条码规则"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextBrush}" />
                <TextBlock Text="员工登录和 VFD 绑定共用扫码枪入口。"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{StaticResource IndustrialTextMutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel>
                <Border x:Name="BarcodeRuleStatusPanel"
                        Padding="12"
                        Background="{StaticResource IndustrialMutedPanelBrush}"
                        BorderBrush="{StaticResource IndustrialBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="规则状态" Style="{StaticResource RuleLabelStyle}" />
                        <TextBlock Text="默认规则已加载"
                                   Margin="0,6,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource IndustrialTextBrush}" />
                        <TextBlock Text="扫码值会先按员工码解析，进入生产后再用于 VFD 条码绑定。"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource IndustrialTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="EmployeeRuleCard"
                        Margin="0,12,0,0"
                        Padding="12"
                        Style="{StaticResource IndustrialSoftCardStyle}">
                    <StackPanel>
                        <TextBlock Text="员工码"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource IndustrialTextBrush}" />
                        <TextBlock Text="{Binding EmployeeRuleDisplay}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource IndustrialTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="VfdRuleCard"
                        Margin="0,12,0,0"
                        Padding="12"
                        Style="{StaticResource IndustrialSoftCardStyle}">
                    <StackPanel>
                        <TextBlock Text="VFD 条码"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource IndustrialTextBrush}" />
                        <TextBlock Text="{Binding VfdRuleDisplay}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource IndustrialTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="12"
                        Background="{StaticResource IndustrialSurfaceBrush}"
                        BorderBrush="{StaticResource IndustrialBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="维护提示" Style="{StaticResource RuleLabelStyle}" />
                        <TextBlock Text="修改规则前先确认现场扫码枪前缀、长度和绑定流程。"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource IndustrialTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
    </ScrollViewer>
</UserControl>
