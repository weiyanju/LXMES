<Window x:Class="VfdControl.App.Views.Engineering.WorkflowAddStepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加步骤"
        Width="560"
        Height="360"
        MinWidth="520"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource IndustrialBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VfdControl.App;component/Resources/IndustrialTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <ScrollViewer x:Name="AddStepContentScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="添加步骤"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource IndustrialTextBrush}" />
            <TextBlock Text="选择逻辑点位并确认步骤名称，判定、写入命令和失败策略在右侧步骤属性中配置。"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource IndustrialTextMutedBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="14"
                Background="{StaticResource IndustrialSurfaceBrush}"
                BorderBrush="{StaticResource IndustrialBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="逻辑点位"
                           Margin="0,0,0,5"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextMutedBrush}" />
                <ComboBox x:Name="AddStepLogicalPointSelector"
                          ItemsSource="{Binding SelectedLogicalPointOptions}"
                          SelectedValue="{Binding SelectedDraftLogicalPointKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="LogicalKey"
                          DisplayMemberPath="DisplayNameWithKey"
                          Style="{StaticResource IndustrialComboBoxStyle}" />

                <TextBlock Text="步骤名称"
                           Margin="0,14,0,5"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextMutedBrush}" />
                <TextBox x:Name="AddStepNameInput"
                         Text="{Binding DraftStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource IndustrialTextBoxStyle}" />

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="添加延时步骤"
                    Click="AddDelayStep"
                    Margin="0,0,8,0"
                    Style="{StaticResource IndustrialCommandButtonStyle}" />
            <Button x:Name="AddStepCompareButton"
                    Content="添加读数比对"
                    Click="AddCompareMeasurementStep"
                    Margin="0,0,8,0"
                    Style="{StaticResource IndustrialCommandButtonStyle}" />
            <Button Content="添加步骤"
                    Click="AddLogicalPointStep"
                    Margin="0,0,8,0"
                    Style="{StaticResource IndustrialPrimaryCommandButtonStyle}" />
            <Button Content="取消"
                    Click="Cancel"
                    Style="{StaticResource IndustrialCommandButtonStyle}" />
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
