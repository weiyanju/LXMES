<UserControl x:Class="VfdControl.App.Views.Engineering.PlanListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="260">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VfdControl.App;component/Resources/IndustrialTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="测试方案"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextBrush}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{StaticResource IndustrialTextMutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                <TextBlock Text="新方案名称"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextMutedBrush}" />
                <TextBox Text="{Binding NewPlanName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,6,0,8"
                         Padding="10,8"
                         Style="{StaticResource IndustrialTextBoxStyle}" />
                <Button Content="创建方案"
                        Command="{Binding CreatePlanCommand}"
                        Style="{StaticResource IndustrialPrimaryCommandButtonStyle}" />
            </StackPanel>

            <ListBox x:Name="PlanListBox"
                     ItemsSource="{Binding Plans}"
                     SelectedItem="{Binding SelectedPlan, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="{StaticResource IndustrialRaisedBrush}"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                Style="{StaticResource IndustrialSoftCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource IndustrialTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LastUpdatedDisplay}"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource IndustrialTextMutedBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
    </DockPanel>
</UserControl>
