<UserControl x:Class="VfdControl.App.Views.Engineering.WorkflowEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VfdControl.App;component/Resources/IndustrialTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="EngineeringStepButtonStyle" TargetType="Button" BasedOn="{StaticResource IndustrialCommandButtonStyle}">
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="MinWidth" Value="104" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="14,7" />
            </Style>

            <Style x:Key="EngineeringSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource IndustrialCommandButtonStyle}">
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="MinWidth" Value="64" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="EngineeringToolbarTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="LineHeight" Value="16" />
                <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale" />
            </Style>

            <Style x:Key="EngineeringToolbarIconStyle" TargetType="TextBlock" BasedOn="{StaticResource EngineeringToolbarTextStyle}">
                <Setter Property="Margin" Value="0,0,7,0" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="EngineeringIconButtonStyle" TargetType="Button" BasedOn="{StaticResource EngineeringSmallButtonStyle}">
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="Width" Value="32" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="EngineeringDeleteIconButtonStyle" TargetType="Button" BasedOn="{StaticResource EngineeringIconButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource IndustrialTextMutedBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource IndustrialDangerBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0,0,0,5" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource IndustrialTextMutedBrush}" />
            </Style>

            <Style x:Key="EditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource IndustrialTextBoxStyle}">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="EditorComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource IndustrialComboBoxStyle}">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="EngineeringPropertyPanelStyle" TargetType="Border">
                <Setter Property="Padding" Value="16" />
                <Setter Property="Background" Value="{StaticResource IndustrialSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource IndustrialBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Effect" Value="{StaticResource IndustrialPanelShadow}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer x:Name="WorkflowEditorContentScroll"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
    <DockPanel x:Name="WorkflowEditorRoot"
               MinWidth="0"
               SizeChanged="WorkflowEditorRootSizeChanged">
        <Grid x:Name="WorkflowHeader" DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding PlanName}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextBrush}" />
            </StackPanel>

            <WrapPanel x:Name="WorkflowHeaderActions"
                       Grid.Column="1"
                       Orientation="Horizontal"
                       VerticalAlignment="Center">
                <Button x:Name="AddWorkflowStepButton"
                        MinHeight="34"
                        Padding="12,6"
                        Click="OpenAddStepDialog"
                        Style="{StaticResource IndustrialCommandButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE710;"
                                   Style="{StaticResource EngineeringToolbarIconStyle}" />
                        <TextBlock Text="添加步骤"
                                   Style="{StaticResource EngineeringToolbarTextStyle}" />
                    </StackPanel>
                </Button>
                <Button x:Name="ValidateWorkflowButton"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Padding="12,6"
                        Command="{Binding ValidateWorkflowCommand}"
                        Style="{StaticResource IndustrialCommandButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE930;"
                                   Style="{StaticResource EngineeringToolbarIconStyle}" />
                        <TextBlock Text="校验方案"
                                   Style="{StaticResource EngineeringToolbarTextStyle}" />
                    </StackPanel>
                </Button>
                <Button x:Name="PublishPlanButton"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Padding="12,6"
                        Command="{Binding SaveVersionCommand}"
                        Style="{StaticResource IndustrialPrimaryCommandButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE898;"
                                   Style="{StaticResource EngineeringToolbarIconStyle}" />
                        <TextBlock Text="发布方案"
                                   Style="{StaticResource EngineeringToolbarTextStyle}" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Grid>

        <Grid x:Name="WorkflowEditorMainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="StepPropertyGapRow" Height="0" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="WorkflowStepColumn" Width="*" MinWidth="0" />
                <ColumnDefinition x:Name="StepPropertyGapColumn" Width="18" />
                <ColumnDefinition x:Name="StepPropertyColumn" Width="420" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="WorkflowStepGrid"
                      Grid.Row="0"
                      Grid.Column="0"
                      ItemsSource="{Binding Steps}"
                      SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      HorizontalScrollBarVisibility="Auto"
                      Style="{StaticResource IndustrialDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="序号" Binding="{Binding Sequence}" Width="58" />
                    <DataGridTextColumn Header="步骤名称" Binding="{Binding Name}" Width="170" />
                    <DataGridTextColumn Header="步骤类型" Binding="{Binding StepTypeDisplay}" Width="120" />
                    <DataGridTextColumn Header="目标/对象" Binding="{Binding TargetSummary}" Width="190" />
                    <DataGridTextColumn Header="判定条件" Binding="{Binding ConditionSummary}" Width="150" />
                    <DataGridTextColumn Header="失败策略" Binding="{Binding FailureActionDisplay}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <Border x:Name="StepPropertyPanel"
                    Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource EngineeringPropertyPanelStyle}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="步骤属性"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource IndustrialTextBrush}" />
                            <TextBlock Text="编辑当前步骤的点位、命令、判定条件与失败策略。"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{StaticResource IndustrialTextMutedBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="10,0,0,0">
                            <Button x:Name="StepCopyButton"
                                    Content="&#xE8C8;"
                                    AutomationProperties.Name="复制步骤"
                                    ToolTip="复制步骤"
                                    Command="{Binding CopySelectedStepCommand}"
                                    Style="{StaticResource EngineeringIconButtonStyle}" />
                            <Button x:Name="StepMoveUpButton"
                                    Content="&#xE74A;"
                                    AutomationProperties.Name="上移步骤"
                                    ToolTip="上移步骤"
                                    Command="{Binding MoveSelectedStepUpCommand}"
                                    Style="{StaticResource EngineeringIconButtonStyle}" />
                            <Button x:Name="StepMoveDownButton"
                                    Content="&#xE74B;"
                                    AutomationProperties.Name="下移步骤"
                                    ToolTip="下移步骤"
                                    Command="{Binding MoveSelectedStepDownCommand}"
                                    Style="{StaticResource EngineeringIconButtonStyle}" />
                            <Button x:Name="StepDeleteButton"
                                    Content="&#xE74D;"
                                    AutomationProperties.Name="删除步骤"
                                    ToolTip="删除步骤"
                                    Command="{Binding RemoveSelectedStepCommand}"
                                    Style="{StaticResource EngineeringDeleteIconButtonStyle}" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="StepPropertyContentScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="步骤名称" Style="{StaticResource EditorLabelStyle}" />
                        <TextBox Text="{Binding SelectedStep.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EditorTextBoxStyle}" />

                        <TextBlock Text="目标点位"
                                   Visibility="{Binding SelectedStep.SinglePointVisibility}"
                                   Style="{StaticResource EditorLabelStyle}" />
                        <ComboBox x:Name="StepLogicalPointSelector"
                                  ItemsSource="{Binding SelectedLogicalPointOptions}"
                                  SelectedValue="{Binding SelectedStep.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="LogicalKey"
                                  DisplayMemberPath="DisplayNameWithKey"
                                  Visibility="{Binding SelectedStep.SinglePointVisibility}"
                                  Style="{StaticResource EditorComboBoxStyle}" />

                        <StackPanel Visibility="{Binding SelectedStep.CompareSettingsVisibility}">
                            <TextBlock Text="点位读数比对" Style="{StaticResource EditorLabelStyle}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="被测读数"
                                               Margin="0,0,0,4"
                                               FontSize="11"
                                               Foreground="{StaticResource IndustrialTextMutedBrush}" />
                                    <ComboBox ItemsSource="{Binding MeasurementPointOptions}"
                                              SelectedValue="{Binding SelectedStep.CompareLeftTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="LogicalKey"
                                              DisplayMemberPath="DisplayNameWithKey"
                                              Style="{StaticResource IndustrialComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="参考读数"
                                               Margin="0,0,0,4"
                                               FontSize="11"
                                               Foreground="{StaticResource IndustrialTextMutedBrush}" />
                                    <ComboBox ItemsSource="{Binding MeasurementPointOptions}"
                                              SelectedValue="{Binding SelectedStep.CompareRightTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="LogicalKey"
                                              DisplayMemberPath="DisplayNameWithKey"
                                              Style="{StaticResource IndustrialComboBoxStyle}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="容差设置" Style="{StaticResource EditorLabelStyle}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox ItemsSource="{Binding ToleranceTypes}"
                                          SelectedItem="{Binding SelectedStep.ToleranceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource IndustrialComboBoxStyle}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding SelectedStep.ToleranceValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource IndustrialTextBoxStyle}" />
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="{Binding SelectedStep.GenericValueLabel}"
                                   Visibility="{Binding SelectedStep.GenericValueVisibility}"
                                   Style="{StaticResource EditorLabelStyle}" />
                        <TextBox Text="{Binding SelectedStep.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding SelectedStep.GenericValueVisibility}"
                                 Style="{StaticResource EditorTextBoxStyle}" />

                        <StackPanel Visibility="{Binding SelectedStep.WriteValueVisibility}">
                            <TextBlock Text="写入命令" Style="{StaticResource EditorLabelStyle}" />
                            <ComboBox x:Name="StepWriteValueSelector"
                                      ItemsSource="{Binding SelectedStepWriteValueOptions}"
                                      SelectedValue="{Binding SelectedStep.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayText"
                                      Style="{StaticResource EditorComboBoxStyle}" />

                            <TextBlock Text="自定义写入值"
                                       Margin="0,-4,0,5"
                                       Style="{StaticResource EditorLabelStyle}" />
                            <TextBox x:Name="StepWriteCustomValueInput"
                                     Text="{Binding SelectedStep.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding SelectedStep.NumericRangeVisibility}">
                            <TextBlock Text="合格范围" Style="{StaticResource EditorLabelStyle}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="下限"
                                               Margin="0,0,0,4"
                                               FontSize="11"
                                               Foreground="{StaticResource IndustrialTextMutedBrush}" />
                                    <TextBox Text="{Binding SelectedStep.LowerLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource IndustrialTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="上限"
                                               Margin="0,0,0,4"
                                               FontSize="11"
                                               Foreground="{StaticResource IndustrialTextMutedBrush}" />
                                    <TextBox Text="{Binding SelectedStep.UpperLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource IndustrialTextBoxStyle}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Visibility="{Binding SelectedStep.StringExpectedVisibility}">
                            <TextBlock Text="期望值" Style="{StaticResource EditorLabelStyle}" />
                            <TextBox Text="{Binding SelectedStep.ExpectedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource EditorTextBoxStyle}" />
                        </StackPanel>

                        <TextBlock Text="失败策略" Style="{StaticResource EditorLabelStyle}" />
                        <ComboBox ItemsSource="{Binding FailureActions}"
                                  SelectedValue="{Binding SelectedStep.FailureAction, Mode=TwoWay}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource EditorComboBoxStyle}" />

                        <TextBlock Text="最大重试次数" Style="{StaticResource EditorLabelStyle}" />
                        <TextBox Text="{Binding SelectedStep.MaxRetries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EditorTextBoxStyle}" />

                        <CheckBox Content="影响最终结论"
                                  IsChecked="{Binding SelectedStep.AffectsFinalConclusion, Mode=TwoWay}"
                                  Margin="0,0,0,10"
                                  Foreground="{StaticResource IndustrialTextBrush}" />
                        <CheckBox Content="启用此步骤"
                                  IsChecked="{Binding SelectedStep.IsEnabled, Mode=TwoWay}"
                                  Foreground="{StaticResource IndustrialTextBrush}" />
                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
    </ScrollViewer>
</UserControl>
