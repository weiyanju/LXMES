<Window x:Class="VfdControl.App.Views.Operator.ScannerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x7CFB;&#x7EDF;&#x626B;&#x7801;&#x67AA;&#x8BBE;&#x7F6E;"
        Width="600"
        Height="460"
        MinWidth="560"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource IndustrialBackgroundBrush}">
    <ScrollViewer x:Name="ScannerSettingsContentScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Border Margin="18"
            Padding="22"
            Background="{DynamicResource IndustrialSurfaceBrush}"
            BorderBrush="{DynamicResource IndustrialBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="&#x7CFB;&#x7EDF;&#x626B;&#x7801;&#x67AA;&#x8BBE;&#x7F6E;"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource IndustrialTextBrush}" />
                <TextBlock Text="&#x8BE5;&#x914D;&#x7F6E;&#x7528;&#x4E8E;&#x5458;&#x5DE5;&#x767B;&#x5F55;&#x548C;&#x751F;&#x4EA7;&#x8FC7;&#x7A0B;&#x4E2D;&#x7684;&#x53D8;&#x9891;&#x5668;&#x6761;&#x7801;&#x7ED1;&#x5B9A;&#x3002;&#x4FDD;&#x5B58;&#x65F6;&#x4F1A;&#x5148;&#x6D4B;&#x8BD5;&#x8FDE;&#x63A5;&#xFF0C;&#x6210;&#x529F;&#x540E;&#x624D;&#x542F;&#x7528;&#x76D1;&#x542C;&#x3002;"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource IndustrialTextSecondaryBrush}" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="COM &#x53E3;"
                               Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource IndustrialTextMutedBrush}" />
                    <ComboBox x:Name="PortComboBox"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="PortName"
                              Style="{DynamicResource IndustrialComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="&#x6CE2;&#x7279;&#x7387;"
                               Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource IndustrialTextMutedBrush}" />
                    <ComboBox x:Name="BaudRateComboBox"
                              Style="{DynamicResource IndustrialComboBoxStyle}" />
                </StackPanel>

                <Button Grid.Column="3"
                        Margin="12,24,0,0"
                        MinWidth="92"
                        Content="&#x5237;&#x65B0;"
                        Click="OnRefreshPortsClick"
                        Style="{DynamicResource IndustrialCommandButtonStyle}" />
            </Grid>

            <Border Grid.Row="4"
                    Padding="14"
                    Background="{DynamicResource IndustrialMutedPanelBrush}"
                    BorderBrush="{DynamicResource IndustrialBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock x:Name="StatusText"
                           Text="&#x672A;&#x8FDE;&#x63A5;&#x3002;&#x9009;&#x62E9;&#x53C2;&#x6570;&#x540E;&#x53EF;&#x6D4B;&#x8BD5;&#xFF0C;&#x6216;&#x76F4;&#x63A5;&#x4FDD;&#x5B58;&#x5E76;&#x8FDE;&#x63A5;&#x3002;"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource IndustrialTextBrush}" />
            </Border>

            <TextBlock Grid.Row="5"
                       Margin="0,14,0,0"
                       Text="&#x70B9;&#x51FB;&#x53D6;&#x6D88;&#x4E0D;&#x4F1A;&#x8FDE;&#x63A5;&#x4E32;&#x53E3;&#xFF0C;&#x5458;&#x5DE5;&#x767B;&#x5F55;&#x4FDD;&#x6301;&#x6A21;&#x62DF;&#x5165;&#x53E3;&#x53EF;&#x7528;&#x3002;"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource IndustrialTextMutedBrush}" />

            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="&#x6D4B;&#x8BD5;&#x8FDE;&#x63A5;"
                        MinWidth="104"
                        Click="OnTestConnectionClick"
                        Style="{DynamicResource IndustrialCommandButtonStyle}" />
                <Button Content="&#x53D6;&#x6D88;"
                        MinWidth="86"
                        Margin="8,0,0,0"
                        Click="OnCancelClick"
                        Style="{DynamicResource IndustrialCommandButtonStyle}" />
                <Button Content="&#x4FDD;&#x5B58;&#x5E76;&#x8FDE;&#x63A5;"
                        MinWidth="128"
                        Margin="8,0,0,0"
                        Click="OnSaveClick"
                        Style="{DynamicResource IndustrialPrimaryCommandButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
    </ScrollViewer>
</Window>
