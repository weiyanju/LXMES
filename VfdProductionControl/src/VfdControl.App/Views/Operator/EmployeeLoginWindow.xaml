<Window x:Class="VfdControl.App.Views.Operator.EmployeeLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x5458;&#x5DE5;&#x767B;&#x5F55;"
        Width="760"
        Height="560"
        MinWidth="660"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource IndustrialBackgroundBrush}">
    <ScrollViewer x:Name="EmployeeLoginContentScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Border Margin="24"
            Padding="26"
            Background="{DynamicResource IndustrialSurfaceBrush}"
            BorderBrush="{DynamicResource IndustrialBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="&#x8BF7;&#x626B;&#x63CF;&#x5458;&#x5DE5;&#x7801;"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource IndustrialTextBrush}" />
                <TextBlock Text="&#x8BE5;&#x7CFB;&#x7EDF;&#x626B;&#x7801;&#x67AA;&#x540C;&#x65F6;&#x7528;&#x4E8E;&#x5458;&#x5DE5;&#x767B;&#x5F55;&#x548C;&#x540E;&#x7EED;&#x53D8;&#x9891;&#x5668;&#x6761;&#x7801;&#x7ED1;&#x5B9A;&#x3002;&#x5F53;&#x524D;&#x672A;&#x63A5;&#x626B;&#x7801;&#x67AA;&#x65F6;&#xFF0C;&#x53EF;&#x7528;&#x4E0B;&#x65B9;&#x6A21;&#x62DF;&#x5165;&#x53E3;&#x8FDB;&#x5165;&#x7CFB;&#x7EDF;&#x3002;"
                           Margin="0,10,0,0"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource IndustrialTextSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,20,0,16"
                    Padding="18"
                    Background="{DynamicResource IndustrialRaisedBrush}"
                    BorderBrush="{DynamicResource IndustrialBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="&#x626B;&#x7801;&#x67AA;&#x72B6;&#x6001;"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource IndustrialTextMutedBrush}" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,6,0,0"
                                   Text="&#x6B63;&#x5728;&#x8FDE;&#x63A5;&#x4E32;&#x53E3;&#x626B;&#x7801;&#x67AA;&#x2026;"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource IndustrialTextBrush}" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Padding="14,12"
                            Background="{DynamicResource IndustrialSurfaceBrush}"
                            BorderBrush="{DynamicResource IndustrialBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="&#x6700;&#x8FD1;&#x626B;&#x7801;"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource IndustrialTextMutedBrush}" />
                            <TextBlock x:Name="LastScanText"
                                       Margin="0,8,0,0"
                                       Text="&#x7B49;&#x5F85;&#x626B;&#x7801;"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource IndustrialAccentStrongBrush}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ScannerConfigText"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource IndustrialTextMutedBrush}" />
                        <Button Grid.Column="1"
                                MinWidth="104"
                                Margin="12,0,0,0"
                                Content="&#x7CFB;&#x7EDF;&#x626B;&#x7801;&#x67AA;&#x8BBE;&#x7F6E;"
                                Click="OnScannerSettingsClick"
                                Style="{DynamicResource IndustrialCommandButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="16"
                    Background="{DynamicResource IndustrialMutedPanelBrush}"
                    BorderBrush="{DynamicResource IndustrialBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MaxWidth="320">
                        <TextBlock Text="&#x4E34;&#x65F6;&#x6A21;&#x62DF;&#x5165;&#x53E3;"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource IndustrialTextBrush}" />
                        <TextBlock Text="&#x7CFB;&#x7EDF;&#x626B;&#x7801;&#x67AA;&#x672A;&#x8FDE;&#x63A5;&#x65F6;&#x4F7F;&#x7528;&#xFF0C;&#x6B63;&#x5F0F;&#x73B0;&#x573A;&#x53EF;&#x5173;&#x95ED;&#x8BE5;&#x7A97;&#x53E3;&#x7B49;&#x5F85;&#x626B;&#x7801;&#x67AA;&#x914D;&#x7F6E;&#x3002;"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource IndustrialTextMutedBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="18,0,0,0"
                                VerticalAlignment="Center">
                        <TextBox x:Name="SimulatedEmployeeCodeInput"
                                 Width="180"
                                 Text="EMP0001"
                                 Style="{DynamicResource IndustrialTextBoxStyle}" />
                        <Button x:Name="SimulateScanButton"
                                Margin="8,0,0,0"
                                MinWidth="132"
                                Content="&#x6A21;&#x62DF;&#x626B;&#x7801;&#x8FDB;&#x5165;"
                                Click="OnSimulateScanClick"
                                Style="{DynamicResource IndustrialPrimaryCommandButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Margin="0,14,0,0"
                       Text="&#x53F3;&#x4E0A;&#x89D2;&#x5173;&#x95ED;&#x7A97;&#x53E3;&#x53EF;&#x9000;&#x51FA;&#x7CFB;&#x7EDF;&#x3002;"
                       FontSize="12"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource IndustrialTextMutedBrush}" />
        </Grid>
    </Border>
    </ScrollViewer>
</Window>
