<UserControl x:Class="VfdControl.App.Views.Operator.SlotCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             MinHeight="440">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VfdControl.App;component/Resources/IndustrialTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="StepResultChipStyle" TargetType="Border">
                <Setter Property="MinWidth" Value="58" />
                <Setter Property="Padding" Value="7,3" />
                <Setter Property="BorderBrush" Value="{StaticResource IndustrialBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="SlotDataLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource IndustrialTextMutedBrush}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Margin="6"
            Padding="12"
            MinHeight="428"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{Binding CardBackgroundColor}"
            BorderBrush="{StaticResource IndustrialBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Effect="{StaticResource IndustrialPanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource IndustrialTextBrush}" />
                        <Border Margin="8,1,0,0"
                                Padding="7,3"
                                Background="{StaticResource IndustrialMutedPanelBrush}"
                                BorderBrush="{StaticResource IndustrialBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock Text="{Binding PortName}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource IndustrialTextSecondaryBrush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding BarcodeDisplay}"
                               Margin="0,5,0,0"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource IndustrialTextMutedBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <Border Padding="10,5"
                            Background="{Binding StatusColor}"
                            BorderBrush="{StaticResource IndustrialBorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource IndustrialTextBrush}" />
                    </Border>
                    <CheckBox Content="已选择"
                              Margin="0,7,0,0"
                              HorizontalAlignment="Right"
                              IsChecked="{Binding IsSelected, Mode=OneWay}"
                              IsHitTestVisible="False"
                              FontSize="11"
                              Foreground="{StaticResource IndustrialTextSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="10,9"
                    Background="{StaticResource IndustrialSurfaceBrush}"
                    BorderBrush="{StaticResource IndustrialBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="执行流程"
                               Margin="0,0,0,8"
                               Style="{StaticResource SlotDataLabelStyle}" />
                    <ScrollViewer VerticalAlignment="Stretch"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding StepRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="66" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="18"
                                                Height="18"
                                                Background="{Binding StatusColor}"
                                                BorderBrush="{StaticResource IndustrialBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="9">
                                            <TextBlock Text="{Binding Sequence}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource IndustrialTextBrush}" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Margin="4,0,8,0">
                                            <TextBlock Text="{Binding StepName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource IndustrialTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding DetailText}"
                                                       Margin="0,2,0,0"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource IndustrialTextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Style="{StaticResource StepResultChipStyle}"
                                                Background="{Binding StatusColor}">
                                            <TextBlock Text="{Binding ConclusionText}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource IndustrialTextSecondaryBrush}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,10,0,0"
                    Padding="10,8"
                    Background="{StaticResource IndustrialMutedPanelBrush}"
                    BorderBrush="{StaticResource IndustrialBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock Text="{Binding LatestCommandText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource IndustrialTextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Border>
</UserControl>
